[
  {
    "id": "auto-restart",
    "execute-command": "/bin/sh",
    "pass-environment-to-command": [
      {
        "source": "payload",
        "name": "alerts.0.labels.job",
        "envname": "TARGET_CONTAINER"
      }
    ],
    "pass-arguments-to-command": [
      {
        "source": "string",
        "name": "-c"
      },
      {
        "source": "string",
        "name": "curl -s -X POST --unix-socket /var/run/docker.sock http://localhost/containers/${TARGET_CONTAINER}/start"
      }
    ]
  }
]